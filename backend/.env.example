# 智慧农业后端 - 环境变量配置
# =====================================================
# 复制本文件为 .env 并填入您的真实凭证后重启后端即可

# 数据库（保持默认即可）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1025
DB_NAME=smart_agriculture

# =====================================================
# Easy IoT MQTT 配置
# 平台地址：https://iot.dfrobot.com.cn/workshop.html
# =====================================================

# 设为 true 开启真实设备接入，false 则使用模拟数据
MQTT_ENABLED=false

# 登录平台工作间后，复制 iot_id 和 iot_pwd 填入下方
MQTT_LOT_ID=GpCFElcvR
MQTT_LOT_PWD=GpjFE_cvgz

# 各传感器对应的 Topic（从工作间卡片上复制）
MQTT_TOPIC_TEMP_HUM=kpdcE_cvg     # 温湿度（DHT22），对应"水"卡片
MQTT_TOPIC_LIGHT=OrltElcDR         # 光照强度（BH1750），对应"1"卡片
MQTT_TOPIC_CO2=0ktAElcvR           # CO₂，对应"2"卡片
MQTT_TOPIC_SOIL=2dhAPlrDR          # 土壤湿度，对应"3"卡片

# 真实数据有效期（秒）：超过此时间未收到数据则回退到模拟
MQTT_REAL_DATA_TTL=30
